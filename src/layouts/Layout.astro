---
import "../styles/global.css";
import Navigation from "../components/Navigation.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Create flower bouquets, or 'tussie mussies', using the language of flowers, or 'floriography'"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Outfit:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header
      class="border-b border-brand-wine/25 bg-gradient-to-r from-brand-wine via-brand-mauve to-brand-wine shadow-md shadow-brand-wine/25"
    >
      <Navigation />
    </header>
    <slot />
    <footer
      class="mt-12 border-t border-brand-wine/30 bg-gradient-to-b from-brand-wine to-brand-forest text-brand-blush/95 relative"
    >
      <div class="victorian-lace-frill absolute left-0 right-0 bottom-full" aria-hidden="true"></div>
    
      <div class="container mx-auto px-4 pb-8 pt-3 overflow-x-auto">
        <p class="text-center text-sm font-light whitespace-nowrap w-max max-w-none mx-auto">
          © {new Date().getFullYear()} Tussie Mussie — the language of flowers.
          Proudly built in Boston. Crafted by Jen Looper · <a
            href="https://beanpot.studio"
            class="text-brand-sky underline decoration-brand-blush/50 underline-offset-2 hover:text-white transition-colors"
            >Beanpot Studio</a
          >
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .prose-flow a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
